{
  "name": "satellite-bor",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "logs": "pm2 logs",
    "dev": "node index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "index.js",
      "src/services/pm2Service.js",
      "src/workers/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "index.js"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pm2": "^5.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
